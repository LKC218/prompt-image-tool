{
  "name": "prompt-image-manager",
  "version": "2.3.1",
  "description": "生图提示词管理器",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"python python/main.py\" \"vite\"",
    "dev:tauri": "tauri dev",
    "build": "vite build",
    "build:tauri": "vite build && tauri build",
    "build:android": "vite build && cap sync android && cap open android",
    "tauri": "tauri",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:python": "python -m pytest python/tests -v",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "npm run test && npm run test:python && npm run test:rust"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/network": "^8.0.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
